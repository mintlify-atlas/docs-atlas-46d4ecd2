  "keyFeatures": [
    "Cross-platform support (Windows, macOS, Linux, Web)",
    "Elm-inspired architecture with type-safe reactive programming",
    "40+ built-in widgets (buttons, text inputs, scrollables, canvas, etc.)",
    "GPU-accelerated rendering with wgpu and software fallback with tiny-skia",
    "Flexible theming and styling system",
    "Async task and subscription support",
    "Custom widget creation",
    "Responsive layout system",
    "Debug tooling with time-travel debugging",
    "Modular architecture with renderer-agnostic runtime"
  ],
  "publicApiSurface": [
    "iced::run - Main entry point for simple applications",
    "iced::application - Builder for complex applications",
    "iced::widget - Built-in widget library (button, text, container, etc.)",
    "iced::Element - Generic widget type",
    "iced::Task - Async task system",
    "iced::Subscription - Passive data subscription system",
    "iced::Theme - Theming and styling",
    "iced::Color - Color manipulation",
    "iced::Length - Widget sizing (Fill, Shrink, Fixed)",
    "iced::Alignment - Widget alignment",
    "iced::window - Window management",
    "iced::clipboard - Clipboard operations",
    "iced::keyboard - Keyboard event handling",
    "iced::mouse - Mouse event handling",
    "iced::font - Font loading and management"
